{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder":      "NIXPACKS",
    "buildCommand": "cd agent && npm ci && npm run build"
  },
  "deploy": {
    "startCommand":            "node agent/dist/index.js",
    "healthcheckPath":         "/",
    "healthcheckTimeout":      30,
    "restartPolicyType":       "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
